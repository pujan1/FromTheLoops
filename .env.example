# =============================================================================
# FromTheLoop — environment template
# Copy to `.env.local` (Next.js) or `.env` (worker) and fill in real values.
# Never commit a populated copy of this file.
# =============================================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (Neon Postgres) ----
# Use a Neon branch URL in dev/staging/prod; local docker-compose uses postgres://...
DATABASE_URL=postgres://fromtheloop:fromtheloop@localhost:5432/fromtheloop

# ---- Redis (BullMQ + cache) ----
REDIS_URL=redis://localhost:6379

# ---- Typesense ----
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=local-dev-key

# ---- Clerk (auth) ----
# https://dashboard.clerk.com — create an application, copy the keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- Sentry (errors, both web + worker) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@fromtheloop.com

# ---- Cloudflare R2 (object storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fromtheloop-uploads
R2_PUBLIC_URL=

# ---- Worker ----
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info
