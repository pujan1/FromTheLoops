# =============================================================================
# FromTheLoop — environment template
# Copy to `.env.local` (Next.js) or `.env` (worker) and fill in real values.
# Never commit a populated copy of this file.
# =============================================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (Neon Postgres) ----
# Use a Neon branch URL in dev/staging/prod; local docker-compose uses postgres://...
DATABASE_URL=postgres://fromtheloop:fromtheloop@localhost:5432/fromtheloop

# ---- Redis (BullMQ + cache) ----
# Local dev: redis://localhost:6379 (the docker-compose Redis)
# Vercel prod: rediss://default:<REDIS_PASSWORD>@box.pujan.tech:6380 (TLS, on Hetzner box)
REDIS_URL=redis://localhost:6379

# ---- Typesense ----
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=local-dev-key

# ---- Clerk (auth) ----
# https://dashboard.clerk.com — create an application, copy the keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# E2E (Playwright) — the sign-in target for the submission flow test. Uses the
# "+clerk_test" subaddress so Clerk treats it as a test identity (no real mail,
# fixed OTP). global.setup.ts creates it via the Backend API if missing.
# Optional — both default in e2e/global.setup.ts.
E2E_CLERK_USER_EMAIL=e2e+clerk_test@fromtheloop.dev
E2E_CLERK_USER_PASSWORD=

# Admin allowlist for /admin/* (e.g. /admin/health). Comma-separated Clerk user
# ids (user_xxx). No RBAC in V1 — this is the gate. Empty = no admins, /admin 404s.
ADMIN_CLERK_IDS=

# ---- Sentry (errors, both web + worker) ----
# Create two projects in Sentry: one Next.js (web), one Node (worker).
# Leave DSNs blank in local dev / CI — the SDK no-ops without them.
SENTRY_DSN=                      # server (web RSC/route handlers) + worker DSN
NEXT_PUBLIC_SENTRY_DSN=          # browser DSN (web client)
SENTRY_ORG=                      # org slug — used by withSentryConfig for source maps
SENTRY_PROJECT=                  # web project slug — source-map upload target
SENTRY_AUTH_TOKEN=               # build-time only; enables source-map upload
# Tag events by deploy environment. Defaults to NODE_ENV when unset.
SENTRY_ENVIRONMENT=              # e.g. production | preview | development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=  # browser-side equivalent

# ---- Resend (transactional email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@fromtheloop.com

# ---- Cloudflare R2 (object storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fromtheloop-uploads
R2_PUBLIC_URL=

# ---- Worker ----
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info
