{
  "name": "@fromtheloop/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Background worker: BullMQ consumer for aggregation, search indexing, email dispatch.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "enqueue:hello": "tsx src/scripts/enqueue-hello.ts",
    "sentry:test": "tsx src/scripts/throw-test.ts",
    "lint": "echo 'TODO: eslint .'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "@fromtheloop/core": "workspace:*",
    "@fromtheloop/db": "workspace:*",
    "@fromtheloop/search": "workspace:*",
    "@fromtheloop/shared": "workspace:*",
    "@sentry/node": "^10.55.0",
    "bullmq": "^5.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "eslint": "^9.17.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0"
  }
}
