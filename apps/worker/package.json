{
  "name": "@fromtheloop/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Background worker: BullMQ consumer for aggregation, search indexing, email dispatch.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "enqueue:hello": "tsx src/scripts/enqueue-hello.ts",
    "sentry:test": "tsx src/scripts/throw-test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fromtheloop/core": "workspace:*",
    "@fromtheloop/db": "workspace:*",
    "@fromtheloop/search": "workspace:*",
    "@fromtheloop/shared": "workspace:*",
    "@sentry/node": "^10.55.0",
    "bullmq": "^5.34.0",
    "dotenv": "^17.4.2",
    "resend": "^4.0.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "typesense": "^3.0.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.17.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
