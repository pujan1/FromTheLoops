{
  "name": "@fromtheloop/db",
  "version": "0.0.0",
  "private": true,
  "description": "Postgres schema, Drizzle ORM, migrations, query helpers.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'TODO: eslint .'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "studio": "drizzle-kit studio",
    "seed": "tsx src/seed/index.ts",
    "seed:reports": "tsx src/seed/reports-run.ts",
    "backfill:aggregates": "tsx src/scripts/backfill-aggregates.ts",
    "autoapprove": "tsx src/scripts/auto-approve-sweep.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/node": "^20.14.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "testcontainers": "^12.0.0",
    "tsx": "^4.22.3",
    "vitest": "^4.1.7"
  }
}
