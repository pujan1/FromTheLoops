# Production env for /opt/fromtheloop/.env.prod on the Hetzner box.
# This file is the public template — copy to .env.prod (gitignored) and fill in real secrets.
# Generate strong values with: openssl rand -base64 32

REDIS_PASSWORD=
TYPESENSE_API_KEY=

# Neon Postgres URL for the worker (purge-deleted-pii cron). Required — the
# worker fails to start without it. Use the prod Neon branch's pooled URL.
DATABASE_URL=

# Resend transactional email — the notifications worker sends the
# submission-confirmed email. Leave blank to disable (send no-ops, job still
# completes). RESEND_FROM_EMAIL defaults to no-reply@fromtheloop.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Worker error reporting. Use the *worker* Sentry project DSN (not the web one).
# Leave blank to disable — the SDK no-ops without it.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# --- Neon free-tier compute budget (see docs/scaling.md rung 1) ---
# The worker must let Neon scale to zero, or its always-on connection burns the
# monthly compute allowance. Defaults below suit the free tier; flip the listener
# on / lower the sweep once on Neon Launch (a plan with no compute cap).
#
# WORKER_EVENT_LISTENER: 'on' holds a permanent LISTEN connection for sub-second
#   outbox delivery (pins Neon awake 24/7). Anything else = off; the fallback
#   sweeps deliver instead. Leave blank/OFF on the free tier.
WORKER_EVENT_LISTENER=
# WORKER_SWEEP_EVERY_MS: how often the aggregate/search/karma sweeps poll Neon.
#   Blank → 30 min (1800000). Must exceed Neon's ~5-min suspend timer. This is
#   the max staleness for new reports hitting aggregates/search/karma.
WORKER_SWEEP_EVERY_MS=
# DB_IDLE_TIMEOUT_S: seconds before idle Postgres connections close (default 20).
#   Required for scale-to-zero — postgres.js otherwise holds them open forever.
DB_IDLE_TIMEOUT_S=
